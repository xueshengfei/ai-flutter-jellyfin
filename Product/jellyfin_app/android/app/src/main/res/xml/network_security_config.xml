<?xml version="1.0" encoding="utf-8"?>
<!-- 允许明文 HTTP（局域网 Jellyfin/AI/TTS/RVC 服务均为 http://） -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
