  class FETCH_ALBUM,FETCH_ARTIST,FETCH_SONG,FETCH_DETAIL_A,FETCH_SONGS_A,FETCH_DETAIL_R,FETCH_ALBUMS_R,SEARCH_FETCH,REMOTE_API,DOWNLOAD_LYRICS,FETCH_LYRICS callback
